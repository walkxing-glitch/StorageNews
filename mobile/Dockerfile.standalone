FROM node:18-alpine

WORKDIR /app

# 安装系统依赖
RUN apk add --no-cache \
    git \
    openssh \
    bash

# 复制所有文件（包括 node_modules）
COPY . .

# 安装依赖
RUN npm install

# 暴露端口
EXPOSE 8081 19000 19001 19002

# 设置环境变量
ENV CI=true
ENV EXPO_DEBUG=true
ENV CHOKIDAR_USEPOLLING=1
ENV WATCHPACK_POLLING=1

CMD ["npx", "expo", "start", "--host", "lan"]