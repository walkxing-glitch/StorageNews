# Production Environment Configuration
# Copy this file to .env.prod and fill in your actual values

# Database Configuration
POSTGRES_USER=storagenews_prod
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=storagenews_prod

# API Keys
NEWSAPI_KEY=your_newsapi_key_here

# Webhook URLs (optional - for enterprise WeChat/WeLink)
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_WEBHOOK_KEY
WELINK_WEBHOOK_URL=https://open.welink.huaweicloud.com/api/webhook/YOUR_WEBHOOK_KEY
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_ACCESS_TOKEN

# WeChat Bot Configuration
WECHAT_BOT_ENABLED=false
WECHAT_TARGET_GROUP=StorageNews情报站

# Scheduling
DAILY_PUSH_TIME=09:00

# Monitoring
GRAFANA_ADMIN_PASSWORD=admin123

# Server Configuration
NODE_ENV=production
PORT=3001
